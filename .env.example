# GitHub App配置
GITHUB_APP_ID=your_github_app_id
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_WEBHOOK_SECRET=your_webhook_secret

# OpenAI API配置(兼容DeepSeek等)
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4

# 数据库配置
# 连接到宿主机的 MySQL（Docker 容器通过 host.docker.internal 访问宿主机）
DATABASE_URL=mysql+aiomysql://pr_reviewer:YOUR_STRONG_PASSWORD@host.docker.internal:3306/pr_reviewer

# Redis配置
# 连接到宿主机的 Redis
REDIS_URL=redis://host.docker.internal:6379/0

# 应用配置
APP_DOMAIN=your-domain.com
APP_PORT=8000
LOG_LEVEL=INFO

# 审查策略配置
MAX_FILE_COUNT=100
MAX_LINE_COUNT=10000
BATCH_SIZE=10

# 标签推荐配置
ENABLE_LABEL_RECOMMENDATION=true
LABEL_CONFIDENCE_THRESHOLD=0.7
LABEL_AUTO_CREATE=false

# Telegram Bot配置
TELEGRAM_BOT_TOKEN=8415833932:AAGtxXgTz7Cxs6WzwfUhGHVEgJk-rY92UNo
TELEGRAM_ADMIN_USER_IDS=5553479213  # 允许使用机器人的用户ID列表，逗号分隔
TELEGRAM_DEFAULT_CHAT_ID=5553479213  # 默认接收通知的聊天ID
