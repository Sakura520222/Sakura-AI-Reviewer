# ============================================================
# Sakura AI Reviewer 配置文件
# ============================================================
#
# 推荐方式：直接启动应用，通过 Setup Wizard (http://localhost:8000/setup) 完成配置。
# 你也可以手动编辑此文件，完成后将其重命名为 .env 即可。
#
# 必填配置项标记为 [必填]，可选配置项标记为 [可选]。
# ============================================================

# ---------- GitHub App 配置 [必填] ----------
GITHUB_APP_ID=your_github_app_id
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_WEBHOOK_SECRET=your_webhook_secret

# ---------- 数据库配置 [必填] ----------
# 连接到宿主机的 MySQL（Docker 容器通过 host.docker.internal 访问宿主机）
DATABASE_URL=mysql+aiomysql://pr_reviewer:YOUR_STRONG_PASSWORD@host.docker.internal:3306/pr_reviewer

# ---------- OpenAI 配置 [必填] ----------
# 支持 OpenAI、DeepSeek、SiliconFlow 等兼容 API
OPENAI_API_KEY=your-openai-api-key
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4

# ---------- Telegram Bot 配置 [必填] ----------
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_ADMIN_USER_IDS=  # 允许使用机器人的用户ID列表，逗号分隔
TELEGRAM_DEFAULT_CHAT_ID=  # 默认接收通知的聊天ID

# ---------- Redis 配置 [可选] ----------
REDIS_URL=redis://host.docker.internal:6379/0

# ---------- 应用配置 [可选] ----------
APP_DOMAIN=your-domain.com
APP_PORT=8000
LOG_LEVEL=INFO

# ---------- WebUI 配置 [可选] ----------
WEBUI_SECRET_KEY=your-random-secret-key-change-in-production

# ---------- GitHub OAuth 配置 [可选] ----------
# 需要在 GitHub Settings > Developer settings > OAuth Apps 中创建
# 配置后可通过 GitHub 账号登录 WebUI
GITHUB_OAUTH_CLIENT_ID=your-github-oauth-client-id
GITHUB_OAUTH_CLIENT_SECRET=your-github-oauth-client-secret
GITHUB_OAUTH_REDIRECT_URI=https://your-domain.com/webui/auth/callback

# ---------- 管理员配置 [Setup Wizard 自动设置] ----------
# 以下配置通过 Setup Wizard 自动设置，通常无需手动编辑
ADMIN_GITHUB_USERNAME=
ADMIN_TELEGRAM_ID=

# ---------- GitHub App 机器人用户名 [自动获取] ----------
# Setup Wizard 在 GitHub App 验证时自动获取，无需手动填写
BOT_USERNAME=
